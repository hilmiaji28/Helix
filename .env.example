# ==========================================================
# HELIX AI Shop API
# Environment Configuration
# ==========================================================

# ==========================================================
# Application
# ==========================================================

APP_NAME=HELIX AI Shop API
APP_VERSION=1.0.0
APP_DESCRIPTION=Machine Learning API for Customer Purchase Prediction
APP_ENV=development
DEBUG=true

# ==========================================================
# Server
# ==========================================================

HOST=0.0.0.0
PORT=8000

# ==========================================================
# API Documentation
# ==========================================================

DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# ==========================================================
# Logging
# ==========================================================

LOG_LEVEL=INFO

# ==========================================================
# Machine Learning Artifacts
# ==========================================================

MODEL_PATH=artifacts/best_model.pkl

FEATURE_METADATA_PATH=artifacts/feature_metadata.pkl

FREQUENCY_MAPS_PATH=artifacts/frequency_maps.pkl

PREPROCESSING_METADATA_PATH=artifacts/preprocessing_metadata.pkl

FEATURE_COLUMNS_PATH=artifacts/feature_columns.pkl

# ==========================================================
# Feature Engineering
# ==========================================================

TARGET_COLUMN=Purchase_Amount

# ==========================================================
# API Settings
# ==========================================================

API_PREFIX=

# ==========================================================
# Future Configuration
# (Reserved for upcoming milestones)
# ==========================================================

ENABLE_METRICS=false

ENABLE_REQUEST_LOGGING=true

ENABLE_SWAGGER=true

ENABLE_REDOC=true

CORS_ORIGINS=*

RATE_LIMIT_ENABLED=false

CACHE_ENABLED=false